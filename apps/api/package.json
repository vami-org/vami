{
  "name": "@vami/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --passWithNoTests",
    "db:migrate": "node -r dotenv/config ./node_modules/node-pg-migrate/bin/node-pg-migrate up --migrations-dir database/migrations",
    "db:rollback": "node -r dotenv/config ./node_modules/node-pg-migrate/bin/node-pg-migrate down --migrations-dir database/migrations",
    "db:seed": "node -r dotenv/config ../../scripts/seed-dev.js"
  },
  "dependencies": {
    "@vami/utils": "workspace:*",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "nodemailer": "^8.0.11",
    "pg": "^8.11.5",
    "pino": "^10.3.1",
    "redis": "^4.6.13",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "node-pg-migrate": "^8.0.4",
    "nodemon": "^3.1.0",
    "supertest": "^6.3.4"
  }
}
